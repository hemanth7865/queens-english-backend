{
  "name": "ant-design-pro",
  "version": "5.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",

  "scripts": {
    "build": "NODE_OPTIONS=--openssl-legacy-provider umi build",
    "serve": "serve -s dist -l $PORT",
    "start": "npm run serve",

    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider umi dev",

    "analyze": "cross-env ANALYZE=1 umi build",
    "lint": "umi g tmp && npm run lint:js && npm run lint:style && npm run lint:prettier && npm run tsc",

    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx ./src",
    "lint:style": "stylelint \"src/**/*.less\" --syntax less",
    "lint:prettier": "prettier -c --write \"src/**/*\" --end-of-line auto",

    "tsc": "tsc --noEmit"
  },

  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],

  "dependencies": {
    "@ant-design/icons": "^4.5.0",
    "@ant-design/pro-descriptions": "^1.6.8",
    "@ant-design/pro-form": "^1.18.3",
    "@ant-design/pro-layout": "^6.15.3",
    "@ant-design/pro-table": "^2.30.8",
    "@react-oauth/google": "^0.8.0",
    "@umijs/route-utils": "^1.0.36",
    "antd": "^4.14.0",
    "classnames": "^2.2.6",
    "country-list": "^2.2.0",
    "file-saver": "^2.0.5",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.11",
    "moment": "^2.25.3",
    "omit.js": "^2.0.2",
    "react": "^17.0.0",
    "react-dom": "^17.0.0",
    "serve": "^14.2.1",
    "uuid": "^8.3.2",
    "antd-button-color": "^1.0.4",
"libphonenumber-js": "^1.9.44",
"react-quill": "^2.0.0",
"react-speech-kit": "^3.0.1"
  },

  "devDependencies": {
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@umijs/fabric": "^2.6.2",
    "@umijs/preset-react": "^1.8.17",
    "cross-env": "^7.0.3",
    "eslint": "^7.1.0",
    "prettier": "^2.3.2",
    "stylelint": "^13.0.0",
    "typescript": "^4.2.2",
    "umi": "^3.5.20"
  },

  "engines": {
    "node": "20.x"
  }
}
